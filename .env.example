# ChatBotura environment variable configuration
# Copy this file to .env and fill in the values.

# Database
DATABASE__PATH=chatbotura.db

# ChromaDB
CHROMA__PATH=chroma_data

# API
API__HOST=0.0.0.0
API__PORT=8000
API__CORS_ORIGINS=["*"]

# LLM
LLM__PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENAI_MODEL=gpt-4o
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_REFERER=https://chatbotura.local
OPENROUTER_TITLE=ChatBotura

# Rate Limiting
RATE_LIMIT__REQUESTS=100
RATE_LIMIT__WINDOW=60

# Logging
LOGGING__LEVEL=INFO
